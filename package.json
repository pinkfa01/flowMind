{
  "name": "flowmind",
  "version": "1.0.0",
  "description": "FlowMind - AI Workbench",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n vite,electron \"vite\" \"wait-on tcp:5173 && electron . --dev\"",
    "build": "vite build",
    "start": "vite build && electron .",
    "dist": "vite build && electron-builder",
    "dist:arm": "vite build && electron-builder --arm64",
    "dist:intel": "vite build && electron-builder --x64",
    "dist:universal": "vite build && electron-builder --universal",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.15.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.flowmind.app",
    "productName": "FlowMind",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ]
    },
    "files": ["dist/**/*", "electron/**/*"],
    "directories": { "output": "release" }
  }
}
